# Copy this file to .streamlit/secrets.toml (local) or paste its contents into
# your app's "Secrets" settings on Streamlit Community Cloud.
# NEVER commit the real secrets.toml file to GitHub — it's already in .gitignore.

sql_server = "myserver.database.windows.net"
sql_database = "BankDB"
sql_schema = "dbo"
sql_port = 1433
sql_username = "your_sql_login"
sql_password = "your_password"
